local httpService = game:GetService('HttpService')
local TweenService = game:GetService('TweenService')

local SaveManager = {}
SaveManager.Folder  = 'CelestraSettings'
SaveManager.Ignore  = {}
SaveManager._window = nil

function SaveManager:SetWindow(window)
    self._window = window
end

function SaveManager:SetFolder(folder)
    self.Folder = folder
    self:BuildFolderTree()
end

function SaveManager:SetIgnoreIndexes(list)
    for _, key in next, list do
        self.Ignore[key] = true
    end
end

function SaveManager:BuildFolderTree()
    for _, path in ipairs({ self.Folder, self.Folder .. '/settings' }) do
        if not isfolder(path) then makefolder(path) end
    end
end

-- ── Save ────────────────────────────────────────────────────
function SaveManager:Save(name)
    if not name or name:gsub(' ', '') == '' then
        return false, 'no config name given'
    end
    local data = { objects = {} }
    for id, elem in next, self._window._elements do
        if self.Ignore[id] then continue end
        local ok, val = pcall(function() return elem:GetValue() end)
        if not ok or val == nil then continue end
        local t = typeof(val)
        local entry
        if t == 'boolean' then
            entry = { type = 'Toggle', idx = id, value = val }
        elseif t == 'number' then
            entry = { type = 'Slider', idx = id, value = val }
        elseif t == 'string' then
            entry = { type = 'Dropdown', idx = id, value = val }
        elseif t == 'Color3' then
            entry = { type = 'ColorPicker', idx = id, value = val:ToHex() }
        end
        if entry then table.insert(data.objects, entry) end
    end
    for id, val in next, self._window._registry do
        if self.Ignore[id] then continue end
        if self._window._elements[id] then continue end
        if type(val) == 'string' then
            table.insert(data.objects, { type = 'TextInput', idx = id, value = val })
        end
    end
    local ok, encoded = pcall(httpService.JSONEncode, httpService, data)
    if not ok then return false, 'encode failed' end
    writefile(self.Folder .. '/settings/' .. name .. '.json', encoded)
    return true
end

-- ── Load ────────────────────────────────────────────────────
function SaveManager:Load(name)
    if not name or name:gsub(' ', '') == '' then
        return false, 'no config name given'
    end
    local path = self.Folder .. '/settings/' .. name .. '.json'
    if not isfile(path) then return false, 'file not found' end
    local ok, decoded = pcall(httpService.JSONDecode, httpService, readfile(path))
    if not ok then return false, 'decode failed' end
    for _, obj in ipairs(decoded.objects) do
        if self.Ignore[obj.idx] then continue end
        local elem = self._window._elements[obj.idx]
        if not elem then continue end
        task.spawn(function()
            if obj.type == 'Toggle' then
                elem:SetValue(obj.value)
            elseif obj.type == 'Slider' then
                elem:SetValue(tonumber(obj.value))
            elseif obj.type == 'Dropdown' then
                elem:SetValue(obj.value)
            elseif obj.type == 'ColorPicker' then
                elem:SetValue(Color3.fromHex(obj.value))
            elseif obj.type == 'TextInput' then
                elem:SetValue(obj.value)
            end
        end)
    end
    return true
end

-- ── Delete ───────────────────────────────────────────────────
function SaveManager:Delete(name)
    if not name or name:gsub(' ', '') == '' then
        return false, 'no config name given'
    end
    local path = self.Folder .. '/settings/' .. name .. '.json'
    if not isfile(path) then return false, 'file not found' end
    local autoloadPath = self.Folder .. '/settings/autoload.txt'
    if isfile(autoloadPath) then
        local autoloaded = readfile(autoloadPath)
        if autoloaded == name then
            return false, 'cannot delete the active autoload config'
        end
    end
    delfile(path)
    return true
end

-- ── Config list ──────────────────────────────────────────────
function SaveManager:RefreshConfigList()
    local list = listfiles(self.Folder .. '/settings')
    local out  = {}
    for _, file in ipairs(list) do
        if file:sub(-5) == '.json' then
            local name = file:match('[/\\]([^/\\]+)%.json$')
            if name then table.insert(out, name) end
        end
    end
    return out
end

-- ── Autoload ─────────────────────────────────────────────────
function SaveManager:LoadAutoload()
    local path = self.Folder .. '/settings/autoload.txt'
    if isfile(path) then
        local name = readfile(path)
        local ok, err = self:Load(name)
        if not ok then
            warn('[SaveManager] Autoload failed: ' .. err)
        else
            print('[SaveManager] Autoloaded: ' .. name)
        end
    end
end

function SaveManager:ResetAutoload()
    local path = self.Folder .. '/settings/autoload.txt'
    if isfile(path) then
        writefile(path, '')
        print('[SaveManager] Autoload cleared')
    end
end

-- ── Ghost button factory (matches library style) ─────────────
local function tw(inst, props, t)
    TweenService:Create(
        inst,
        TweenInfo.new(t or 0.12, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
        props
    ):Play()
end

local function makeGhostButton(parent, text, xOffset, width, isDanger)
    local btn = Instance.new('TextButton')
    btn.Size             = UDim2.new(0, width, 0, 24)
    btn.Position         = UDim2.new(1, xOffset, 0.5, -12)
    btn.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
    btn.BorderSizePixel  = 0
    btn.Text             = text
    btn.TextColor3       = isDanger and Color3.fromRGB(210, 100, 100) or Color3.fromRGB(160, 160, 160)
    btn.TextSize         = 11
    btn.Font             = Enum.Font.GothamBold
    btn.ZIndex           = 3
    btn.Parent           = parent

    local c = Instance.new('UICorner')
    c.CornerRadius = UDim.new(0, 4)
    c.Parent = btn

    local s = Instance.new('UIStroke')
    s.Color           = isDanger and Color3.fromRGB(90, 35, 35) or Color3.fromRGB(42, 42, 42)
    s.Thickness       = 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent          = btn

    local normalBg     = Color3.fromRGB(22, 22, 22)
    local hoverBg      = Color3.fromRGB(28, 28, 28)
    local pressBg      = Color3.fromRGB(32, 32, 32)
    local normalStroke = isDanger and Color3.fromRGB(90,  35, 35) or Color3.fromRGB(42, 42, 42)
    local hoverStroke  = isDanger and Color3.fromRGB(130, 45, 45) or Color3.fromRGB(60, 60, 60)

    btn.MouseEnter:Connect(function()
        tw(btn, { BackgroundColor3 = hoverBg })
        tw(s,   { Color = hoverStroke })
    end)
    btn.MouseLeave:Connect(function()
        tw(btn, { BackgroundColor3 = normalBg })
        tw(s,   { Color = normalStroke })
    end)
    btn.MouseButton1Down:Connect(function()
        tw(btn, { BackgroundColor3 = pressBg }, 0.06)
    end)
    btn.MouseButton1Up:Connect(function()
        tw(btn, { BackgroundColor3 = hoverBg }, 0.06)
    end)

    return btn
end

-- ── Twin-button row ───────────────────────────────────────────
local function addTwinButtons(card, rowTitle, rowDesc, btnAText, btnBText, btnBDanger, cbA, cbB)
    card._rowOrder = card._rowOrder + 1

    local row = Instance.new('Frame')
    row.Size                   = UDim2.new(1, 0, 0, 52)
    row.BackgroundTransparency = 1
    row.BorderSizePixel        = 0
    row.LayoutOrder            = card._rowOrder
    row.ZIndex                 = 2
    row.Parent                 = card._card

    local lbl = Instance.new('TextLabel')
    lbl.Size                   = UDim2.new(1, -220, 0, 20)
    lbl.Position               = UDim2.new(0, 16, 0, 8)
    lbl.BackgroundTransparency = 1
    lbl.Text                   = rowTitle or ''
    lbl.TextColor3             = Color3.fromRGB(215, 215, 215)
    lbl.TextSize               = 13
    lbl.Font                   = Enum.Font.GothamBold
    lbl.TextXAlignment         = Enum.TextXAlignment.Left
    lbl.ZIndex                 = 2
    lbl.Parent                 = row

    local desc = Instance.new('TextLabel')
    desc.Size                   = UDim2.new(1, -220, 0, 15)
    desc.Position               = UDim2.new(0, 16, 0, 30)
    desc.BackgroundTransparency = 1
    desc.Text                   = rowDesc or ''
    desc.TextColor3             = Color3.fromRGB(72, 72, 72)
    desc.TextSize               = 11
    desc.Font                   = Enum.Font.Gotham
    desc.TextXAlignment         = Enum.TextXAlignment.Left
    desc.ZIndex                 = 2
    desc.Parent                 = row

    local btnA = makeGhostButton(row, btnAText, -210, 96, false)
    local btnB = makeGhostButton(row, btnBText, -106, 96, btnBDanger)

    btnA.MouseButton1Up:Connect(function() if cbA then cbA() end end)
    btnB.MouseButton1Up:Connect(function() if cbB then cbB() end end)
end

-- ── BuildConfigPage ──────────────────────────────────────────
function SaveManager:BuildConfigPage(page)
    assert(self._window,           'Call SaveManager:SetWindow(Window) first')
    assert(self._window._elements, 'Window._elements missing — add it to libary.txt before return Window')

    local card = page:AddCard('Configuration')

    card:AddTextInput('SaveManager_Name', {
        Title       = 'Config Name',
        Desc        = 'Name your config, then hit Save.',
        Placeholder = 'my_config',
    })

    card:AddDropdown('SaveManager_List', {
        Title   = 'Saved Configs',
        Desc    = 'Pick a config to load, overwrite, or delete.',
        Options = self:RefreshConfigList(),
    })

    card:AddDivider()

    -- Refreshes the dropdown list after save/delete without requiring a rejoin
    local function refreshList()
        local elem = self._window._elements['SaveManager_List']
        if elem and elem.SetOptions then
            elem:SetOptions(self:RefreshConfigList())
        end
    end

    -- Row 1: Save | Load
    addTwinButtons(card,
        'Save / Load', 'Save new config or load selected.',
        'Save', 'Load', false,
        function()
            local name = self._window._registry['SaveManager_Name']
            local ok, err = self:Save(name)
            if ok then
                print('[SaveManager] Saved: ' .. name)
                refreshList()
            else
                warn('[SaveManager] Save failed: ' .. tostring(err))
            end
        end,
        function()
            local name = self._window._registry['SaveManager_List']
            local ok, err = self:Load(name)
            if ok then
                print('[SaveManager] Loaded: ' .. name)
            else
                warn('[SaveManager] Load failed: ' .. tostring(err))
            end
        end
    )

    -- Row 2: Overwrite | Delete
    addTwinButtons(card,
        'Overwrite / Delete', 'Overwrite or permanently remove selected.',
        'Overwrite', 'Delete', true,
        function()
            local name = self._window._registry['SaveManager_List']
            local ok, err = self:Save(name)
            if ok then
                print('[SaveManager] Overwrote: ' .. name)
            else
                warn('[SaveManager] Overwrite failed: ' .. tostring(err))
            end
        end,
        function()
            local name = self._window._registry['SaveManager_List']
            local ok, err = self:Delete(name)
            if ok then
                print('[SaveManager] Deleted: ' .. name)
                refreshList()
            else
                warn('[SaveManager] Delete failed: ' .. tostring(err))
            end
        end
    )

    -- Row 3: Set Autoload | Reset Autoload
    addTwinButtons(card,
        'Autoload', 'Auto-load selected config on every script run.',
        'Set Autoload', 'Reset', false,
        function()
            local name = self._window._registry['SaveManager_List']
            if name and name ~= '' then
                writefile(self.Folder .. '/settings/autoload.txt', name)
                print('[SaveManager] Autoload set to: ' .. name)
            end
        end,
        function()
            self:ResetAutoload()
        end
    )

    self:SetIgnoreIndexes({ 'SaveManager_Name', 'SaveManager_List' })
end

SaveManager:BuildFolderTree()
return SaveManager
