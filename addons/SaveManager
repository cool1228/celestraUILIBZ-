local httpService = game:GetService('HttpService')

local SaveManager = {}
SaveManager.Folder  = 'CelestraSettings'
SaveManager.Ignore  = {}
SaveManager._window = nil

function SaveManager:SetWindow(window)
    self._window = window
end

function SaveManager:SetFolder(folder)
    self.Folder = folder
    self:BuildFolderTree()
end

function SaveManager:SetIgnoreIndexes(list)
    for _, key in next, list do
        self.Ignore[key] = true
    end
end

function SaveManager:BuildFolderTree()
    for _, path in ipairs({ self.Folder, self.Folder .. '/settings' }) do
        if not isfolder(path) then makefolder(path) end
    end
end

-- ── Save ────────────────────────────────────────────────────
function SaveManager:Save(name)
    if not name or name:gsub(' ', '') == '' then
        return false, 'no config name given'
    end

    local data = { objects = {} }

    for id, elem in next, self._window._elements do
        if self.Ignore[id] then continue end

        local ok, val = pcall(function() return elem:GetValue() end)
        if not ok or val == nil then continue end

        local t = typeof(val)
        local entry

        if t == 'boolean' then
            entry = { type = 'Toggle', idx = id, value = val }
        elseif t == 'number' then
            entry = { type = 'Slider', idx = id, value = val }
        elseif t == 'string' then
            entry = { type = 'Dropdown', idx = id, value = val }
        elseif t == 'Color3' then
            entry = { type = 'ColorPicker', idx = id, value = val:ToHex() }
        end

        if entry then
            table.insert(data.objects, entry)
        end
    end

    -- also save TextInput from registry (strings stored directly)
    for id, val in next, self._window._registry do
        if self.Ignore[id] then continue end
        if self._window._elements[id] then continue end -- already saved above
        if type(val) == 'string' then
            table.insert(data.objects, { type = 'TextInput', idx = id, value = val })
        end
    end

    local ok, encoded = pcall(httpService.JSONEncode, httpService, data)
    if not ok then return false, 'encode failed' end

    writefile(self.Folder .. '/settings/' .. name .. '.json', encoded)
    return true
end

-- ── Load ────────────────────────────────────────────────────
function SaveManager:Load(name)
    if not name or name:gsub(' ', '') == '' then
        return false, 'no config name given'
    end

    local path = self.Folder .. '/settings/' .. name .. '.json'
    if not isfile(path) then return false, 'file not found' end

    local ok, decoded = pcall(httpService.JSONDecode, httpService, readfile(path))
    if not ok then return false, 'decode failed' end

    for _, obj in ipairs(decoded.objects) do
        if self.Ignore[obj.idx] then continue end

        local elem = self._window._elements[obj.idx]
        if not elem then continue end

        task.spawn(function()
            if obj.type == 'Toggle' then
                elem:SetValue(obj.value)
            elseif obj.type == 'Slider' then
                elem:SetValue(tonumber(obj.value))
            elseif obj.type == 'Dropdown' then
                elem:SetValue(obj.value)
            elseif obj.type == 'ColorPicker' then
                elem:SetValue(Color3.fromHex(obj.value))
            elseif obj.type == 'TextInput' then
                elem:SetValue(obj.value)
            end
        end)
    end

    return true
end

-- ── Config list ──────────────────────────────────────────────
function SaveManager:RefreshConfigList()
    local list = listfiles(self.Folder .. '/settings')
    local out  = {}
    for _, file in ipairs(list) do
        if file:sub(-5) == '.json' then
            local name = file:match('[/\\]([^/\\]+)%.json$')
            if name then table.insert(out, name) end
        end
    end
    return out
end

-- ── Autoload ─────────────────────────────────────────────────
function SaveManager:LoadAutoload()
    local path = self.Folder .. '/settings/autoload.txt'
    if isfile(path) then
        local name = readfile(path)
        local ok, err = self:Load(name)
        if not ok then
            warn('[SaveManager] Autoload failed: ' .. err)
        else
            print('[SaveManager] Autoloaded: ' .. name)
        end
    end
end

function SaveManager:ResetAutoload()
    local path = self.Folder .. '/settings/autoload.txt'
    if isfile(path) then
        writefile(path, '')
        print('[SaveManager] Autoload cleared')
    end
end

-- ── BuildConfigPage ──────────────────────────────────────────
function SaveManager:BuildConfigPage(page)
    assert(self._window, 'Call SaveManager:SetWindow(Window) first')
    assert(self._window._elements, 'Add Window._elements = Elements to libary.txt before return Window')

    local card = page:AddCard('Configuration')

    card:AddTextInput('SaveManager_Name', {
        Title       = 'Config Name',
        Desc        = 'Name for your new config file.',
        Placeholder = 'my_config',
    })

    card:AddDropdown('SaveManager_List', {
        Title   = 'Config List',
        Desc    = 'Select a saved config to load or overwrite.',
        Options = self:RefreshConfigList(),
    })

    card:AddDivider()

    -- Save
    card:AddButton('SaveManager_SaveBtn', {
        Title      = 'Save Config',
        Desc       = 'Save current settings under the typed name.',
        ButtonText = 'Save',
        Callback   = function()
            local name = self._window._registry['SaveManager_Name']
            local ok, err = self:Save(name)
            if ok then
                print('[SaveManager] Saved: ' .. name)
                local elem = self._window._elements['SaveManager_List']
                if elem then
                    local configs = self:RefreshConfigList()
                    elem:SetValue(configs[1] or '')
                end
            else
                warn('[SaveManager] Save failed: ' .. tostring(err))
            end
        end,
    })

    -- Load
    card:AddButton('SaveManager_LoadBtn', {
        Title      = 'Load Config',
        Desc       = 'Load the selected config from the list.',
        ButtonText = 'Load',
        Callback   = function()
            local name = self._window._registry['SaveManager_List']
            local ok, err = self:Load(name)
            if ok then
                print('[SaveManager] Loaded: ' .. name)
            else
                warn('[SaveManager] Load failed: ' .. tostring(err))
            end
        end,
    })

    -- Overwrite
    card:AddButton('SaveManager_OverwriteBtn', {
        Title      = 'Overwrite Config',
        Desc       = 'Overwrite the selected config with current settings.',
        ButtonText = 'Overwrite',
        Callback   = function()
            local name = self._window._registry['SaveManager_List']
            local ok, err = self:Save(name)
            if ok then
                print('[SaveManager] Overwrote: ' .. name)
            else
                warn('[SaveManager] Overwrite failed: ' .. tostring(err))
            end
        end,
    })

    -- Set Autoload
    card:AddButton('SaveManager_AutoloadBtn', {
        Title      = 'Set Autoload',
        Desc       = 'Auto-load this config every time the script runs.',
        ButtonText = 'Set',
        Callback   = function()
            local name = self._window._registry['SaveManager_List']
            if name and name ~= '' then
                writefile(self.Folder .. '/settings/autoload.txt', name)
                print('[SaveManager] Autoload set to: ' .. name)
            end
        end,
    })

    -- Reset Autoload
    card:AddButton('SaveManager_ResetAutoloadBtn', {
        Title      = 'Reset Autoload',
        Desc       = 'Clear the autoload so no config loads on startup.',
        ButtonText = 'Reset',
        Callback   = function()
            self:ResetAutoload()
        end,
    })

    self:SetIgnoreIndexes({ 'SaveManager_Name', 'SaveManager_List' })
end

SaveManager:BuildFolderTree()
return SaveManager
